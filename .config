# 平台配置（MT7628NN 专属）
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt76x8=y
CONFIG_TARGET_ramips_mt76x8_DEVICE_generic=y

# 固件格式（适配16MB闪存）
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_JFFS2=n
CONFIG_TARGET_UBIFS_FS=n

# 4G模块核心驱动（CSH50-01 通吃）
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y

# 4G拨号服务（自动拨号，无需APN）
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_luci-app-modemmanager=y
CONFIG_PACKAGE_luci-app-3ginfo-lite=y
CONFIG_PACKAGE_qmi-wwan=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_uqmi=y

# 去广告功能（AdGuard Home 开机自启）
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# 路由基础功能
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-ipset=y

# 中文LuCI界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-modemmanager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# 系统工具
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_luci-app-commands=y

# 固定网络配置（后台192.168.1.1永不丢失）
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_DEFAULT_ipv6=n
CONFIG_LUCI_SRCDIET=y
